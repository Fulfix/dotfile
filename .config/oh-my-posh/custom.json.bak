{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "#f6ec80",
          "properties": {
            "style": "full"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#965942",
          "properties": {
            "branch_icon": ""
          }
        },
        {
          "type": "exit",
          "style": "plain",
          "foreground": "#423731"
        }
      ]
    }
  ]
}
