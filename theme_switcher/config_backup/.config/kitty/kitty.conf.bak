clipboard_control write_to_clipboard_command wl-copy
clipboard_control read_from_clipboard_command wl-paste
map super+c copy_to_clipboard
map super+v paste_from_clipboard
include /home/thomas/.config/kitty/themes/gruvbox_dark.conf
touch_scroll_multiplier 9.0
map super+backspace send_text all \x17
map alt+k send_key up
map alt+j send_key down
map alt+h send_key left
map alt+l send_key right
map super+shift+h send_key alt+left
map super+shift+l send_key alt+right
enable_audio_bell no



# BEGIN_KITTY_FONTS
font_family "FiraCode Nerd Font Med"
font_size 12

bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
